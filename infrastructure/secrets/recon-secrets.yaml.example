# Example only. Copy to recon-secrets.yaml and fill in real values, OR create the
# Secret out-of-band. Never commit real secret values.
apiVersion: v1
kind: Secret
metadata:
  name: recon-secrets
  namespace: recon
type: Opaque
stringData:
  API_KEY: CHANGE_ME        # shared API key for the ReID services
  MONGODB_URI: CHANGE_ME    # e.g. mongodb://mongodb-0.mongodb.recon.svc.cluster.local:27017/repository_reid?replicaSet=rs0
