# Example only. Copy to ai-secrets.yaml and fill in real values, OR create the
# Secret out-of-band with `kubectl -n ai create secret generic ai-secrets ...`.
# Never commit real secret values.
apiVersion: v1
kind: Secret
metadata:
  name: ai-secrets
  namespace: ai
type: Opaque
stringData:
  API_KEY: CHANGE_ME              # shared API key services authenticate with
  API_KEYS: CHANGE_ME             # comma-separated accepted keys (communicator)
  CUSTOM_API_URL: CHANGE_ME       # optional custom LLM endpoint
  CUSTOM_API_KEY: CHANGE_ME       # optional custom LLM key
  CUSTOM_API_MODEL: CHANGE_ME     # optional custom model id
  CLICKUP_API_KEY: CHANGE_ME      # ClickUp personal token (clickup-agent)
  SERPER_API_KEY: CHANGE_ME       # Serper search key (if web search is enabled)
