# Example only. Optional: only needed if the communicator uses the SSH OAuth-refresh
# side channel. Copy to communicator-refresh-ssh.yaml and supply your own key, OR
# create the Secret out-of-band. Never commit a real private key.
apiVersion: v1
kind: Secret
metadata:
  name: communicator-refresh-ssh
  namespace: ai
type: Opaque
stringData:
  id_ed25519: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    CHANGE_ME
    -----END OPENSSH PRIVATE KEY-----
  known_hosts: |
    CHANGE_ME   # e.g. "[your-ssh-host]:port ssh-ed25519 AAAA..."
